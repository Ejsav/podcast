# ─────────────────────────────────────────────────────────────
# Local Famous — environment variables
# Copy this file to `.env.local` for local dev, or set the same
# keys in Vercel → Project → Settings → Environment Variables.
# Every variable below is OPTIONAL — the app works without any
# of them by falling back to console logs in dev/preview.
# ─────────────────────────────────────────────────────────────

# Public site origin used by RSS feed, sitemap, robots, OpenGraph.
# No trailing slash. Defaults to https://localfamous.fm.
NEXT_PUBLIC_SITE_URL=https://localfamous.fm

# ─── Email & forms (Resend) ──────────────────────────────────
# Get a key at https://resend.com (free tier: 3k emails/mo).
RESEND_API_KEY=

# Inbox that receives form notifications (tip line, be-featured,
# newsletter signups when no audience is configured).
LF_NOTIFY_EMAIL=hello@localfamous.fm

# Verified Resend sender. Must match a domain you've verified
# in the Resend dashboard. Format: "Name <addr@domain>".
LF_FROM_EMAIL=Local Famous <hello@localfamous.fm>

# Optional — if set, newsletter signups are added to this Resend
# audience instead of just emailed to the team.
RESEND_AUDIENCE_ID=
